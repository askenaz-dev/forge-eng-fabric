# Local dev defaults — copy to .env.local
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-me
KEYCLOAK_CLIENT_ID=forge-portal
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=http://localhost:8080/realms/forge
CONTROL_PLANE_URL=http://localhost:8081
REGISTRY_URL=http://localhost:8082
OPENSPEC_URL=http://localhost:8083
APP_ONBOARDING_URL=http://localhost:8085
SDLC_ORCHESTRATOR_URL=http://localhost:8089
TRACEABILITY_URL=http://localhost:8090
FINOPS_URL=http://localhost:8122

# AI-Flow editor (ai-flow-authoring change). The visual React Flow canvas at
# /workflows/editor is gated on this flag. Default in dev is `true` so the
# canvas is the authoring surface out of the box. Set to `false` to fall
# back to the read-only library notice.
AI_FLOWS_CANVAS_ENABLED=true

# trigger-router, model-gateway, prompt-template-service endpoints.
WORKFLOW_REGISTRY_URL=http://localhost:8094
WORKFLOW_RUNTIME_URL=http://localhost:8093
TRIGGER_ROUTER_URL=http://localhost:8097
MODEL_GATEWAY_URL=http://localhost:8098
PROMPT_TEMPLATE_URL=http://localhost:8099
# Alfred (alfred-litellm-header-injection G2) dispatches `prompt:<id>:render`
# tools to prompt-template-service via this var. Same target as
# PROMPT_TEMPLATE_URL above; named separately so the alfred service can be
# wired independently of the portal's editor surface.
PROMPT_TEMPLATE_SERVICE_URL=http://localhost:8099
