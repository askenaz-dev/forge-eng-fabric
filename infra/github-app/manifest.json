{
  "name": "Forge",
  "url": "http://localhost:3000",
  "hook_attributes": {
    "url": "http://localhost:8081/v1/github/webhook"
  },
  "redirect_url": "http://localhost:3000/github/callback",
  "callback_urls": [
    "http://localhost:3000/github/callback"
  ],
  "public": false,
  "default_permissions": {
    "metadata": "read",
    "members": "read",
    "contents": "write",
    "pull_requests": "write",
    "administration": "write",
    "actions": "write",
    "checks": "write"
  },
  "default_events": [
    "installation",
    "installation_repositories",
    "repository",
    "pull_request",
    "push",
    "check_run",
    "check_suite",
    "workflow_run"
  ],
  "request_oauth_on_install": true,
  "setup_url": "http://localhost:3000/settings/github",
  "setup_on_update": true
}
